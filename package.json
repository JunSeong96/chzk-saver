{
  "private": true,
  "type": "module",
  "scripts": {
    "build:extension": "vite build --config vite.extension.config.ts",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "validate:extension": "node scripts/validate-extension-build.mjs",
    "perf-lab": "node scripts/perf-lab-server.mjs",
    "smoke:extension:whale": "node scripts/smoke-extension-whale.mjs",
    "verify:extension": "npm run typecheck:extension && npm run build:extension && npm run validate:extension"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@types/chrome": "^0.0.305",
    "playwright": "^1.61.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.16"
  }
}
