{
  "manifest_version": 3,
  "name": "치직 세이버",
  "version": "0.1.3",
  "description": "치지직 다시보기와 클립 링크를 입력해 MP4로 저장할 수 있는 확장 프로그램입니다.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "치직 세이버",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "downloads", "offscreen", "declarativeNetRequest"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "chzzk_header_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*",
    "https://apis.naver.com/*",
    "https://*.navercdn.com/*",
    "https://*.akamaized.net/*",
    "https://*.pstatic.net/*"
  ]
}
